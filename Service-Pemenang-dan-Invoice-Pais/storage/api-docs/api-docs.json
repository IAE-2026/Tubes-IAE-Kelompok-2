{
    "openapi": "3.0.0",
    "info": {
        "title": "Invoice Winner API",
        "description": "API Documentation",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://127.0.0.1:8000",
            "description": "Local Server"
        }
    ],
    "paths": {
        "/api/v1/invoices": {
            "get": {
                "tags": [
                    "Invoices"
                ],
                "summary": "Daftar invoice",
                "description": "Menampilkan daftar invoice dengan pagination. Bisa difilter berdasarkan status.",
                "operationId": "bc7d90facaef99e1846d581b3a3b6efa",
                "parameters": [
                    {
                        "name": "status",
                        "in": "query",
                        "description": "Filter berdasarkan status: unpaid, paid, overdue",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "enum": [
                                "unpaid",
                                "paid",
                                "overdue"
                            ]
                        }
                    },
                    {
                        "name": "per_page",
                        "in": "query",
                        "description": "Jumlah data per halaman (default: 10)",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 10
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Daftar invoice berhasil diambil",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "success"
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Daftar invoice berhasil diambil."
                                        },
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "type": "object"
                                            }
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized: Bearer token is missing."
                    }
                }
            },
            "post": {
                "tags": [
                    "Invoices"
                ],
                "summary": "Buat invoice",
                "operationId": "2a3d332a2b06bcf3aa6a68444f786beb",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "auction_id": {
                                        "type": "string",
                                        "example": "AUC-001"
                                    },
                                    "use_mock": {
                                        "type": "boolean",
                                        "example": true
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Invoice created"
                    }
                }
            }
        },
        "/api/v1/invoices/{id}": {
            "get": {
                "tags": [
                    "Invoices"
                ],
                "summary": "Detail invoice",
                "description": "Menampilkan detail invoice berdasarkan ID atau Nomor Invoice beserta pemenang terkait.",
                "operationId": "8e26839ec5797200db20667a31142ea0",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID atau Nomor Invoice",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "example": "INV-2024-000001"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Detail invoice berhasil diambil",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "success"
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Detail invoice berhasil diambil."
                                        },
                                        "data": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized: Bearer token is missing."
                    },
                    "404": {
                        "description": "Invoice tidak ditemukan."
                    }
                }
            }
        },
        "/api/test": {
            "get": {
                "tags": [
                    "Test"
                ],
                "summary": "Test endpoint",
                "operationId": "220d3fafb11bb6c6b5cb44324a082216",
                "responses": {
                    "200": {
                        "description": "Success"
                    }
                }
            }
        }
    },
    "tags": [
        {
            "name": "Invoices",
            "description": "Invoices API"
        },
        {
            "name": "Test",
            "description": "Test"
        }
    ]
}